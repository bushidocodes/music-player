{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2025"],
    "types": ["node"]
  },
  "include": [
    "server/**/*.ts",
    "bin/**/*.ts",
    "scripts/**/*.ts",
    "vite.config.ts",
    "vitest.config.ts"
  ],
  "exclude": ["node_modules", "public", "browser", "server/**/*.test.ts"]
}
